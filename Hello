import os
from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from cryptography.hazmat.backends import default_backend
from secretsharing import PlaintextToHexSecretSharer

def encrypt_file(file_path):
    aes_key = os.urandom(32) 
    
    # 2. Tạo vector khởi tạo (IV) để đảm bảo cùng 1 file mã hóa 2 lần sẽ ra 2 kết quả khác nhau
    iv = os.urandom(16)
    
    # 3. Đọc dữ liệu file gốc
    with open(file_path, 'rb') as f:
        data = f.read()

    # 4. Thiết lập thuật toán AES chế độ CFB (không cần padding dữ liệu)

    cipher = Cipher(algorithms.AES(aes_key), modes.CFB(iv), backend=default_backend())
    encryptor = cipher.encryptor()
    encrypted_data = encryptor.update(data) + encryptor.finalize()
    # 5. Lưu file đã mã hóa xuống server (.enc)
    with open(file_path + ".enc", 'wb') as f:
        f.write(iv + encrypted_data) # Lưu IV ở đầu file để sau này giải mã
        
    return aes_key # Trả về khóa để đem đi chia nhỏ bằng Shamir


def split_key_shamir(aes_key, threshold, total_shares):
    # 1. Chuyển khóa AES (dạng bytes) sang dạng Hex (chuỗi ký tự) để thư viện đọc được
    key_hex = aes_key.hex()
    
    # 2. Dùng thuật toán Shamir chia khóa
    # threshold (k): Số lượng tối thiểu để khôi phục (ví dụ: 3)
    # total_shares (n): Tổng số mảnh phát ra (ví dụ: 5)
    shares = PlaintextToHexSecretSharer.split_secret(key_hex, threshold, total_shares)
    
    return shares # Trả về danh sách các mảnh: ['1-abc...', '2-def...', ...]

def recover_key_and_decrypt(received_shares, encrypted_file_path):
    # 1. Gộp các mảnh lại để lấy lại khóa AES Hex ban đầu
    recovered_key_hex = PlaintextToHexSecretSharer.recover_secret(received_shares)
    recovered_key_bytes = bytes.fromhex(recovered_key_hex)
    
    # 2. Mở file .enc và tách IV ra khỏi dữ liệu
    with open(encrypted_file_path, 'rb') as f:
        file_data = f.read()
        iv = file_data[:16] # 16 byte đầu là IV
        actual_encrypted_data = file_data[16:]
        
    # 3. Tiến hành giải mã ngược lại
    cipher = Cipher(algorithms.AES(recovered_key_bytes), modes.CFB(iv), backend=default_backend())
    decryptor = cipher.decryptor()
    original_data = decryptor.update(actual_encrypted_data) + decryptor.finalize()
    
